# Neon PostgreSQL (production / cloud)
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Local Docker Postgres (alternative)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=ims
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_SSLMODE=disable

# Application
APP_PORT=3000

# Authentication
JWT_SECRET=change-this-to-a-long-random-string
ADMIN_EMAIL=admin@ims.local
ADMIN_PASSWORD=admin123
# Set AUTH_DISABLED=true only for local Swagger testing without tokens
AUTH_DISABLED=false
