# Option A: Neon / Supabase / cloud Postgres (recommended for production)
# Paste the full connection string from your provider dashboard.
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Option B: Individual variables (local Docker)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=ims
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_SSLMODE=disable

# Application
APP_PORT=3000
